{
    "_class_name": "GroupRelativePolicyOptimization",
    "_config": {
        // diffusion
        "sampling_timestep": {
            "_class_name": "TrailingSamplingTimesteps",
            "_config": {
                "T": 1000,
                "num_sampling_steps": 4,
                "shift": 5.0
            }
        },
        "schedule": {
            "_class_name": "LinearInterpolationSchedule",
            "_config": {
                "T": 1000,
                "pred_type": "v_lerp"
            }
        },
        "sampler": {
            "_class_name": "EulerMaruyamaSampler",
            "_config": {
                "noise_level": 0.8
            }
        },
        // general
        "validation": [
        {
            "name": "vbenchdd_64x4",
            "_class_name": "GenerateT2V",
            "_config": {
                "meta_cfg": {
                    "guidance_scale": 3.0,
                    "chunk_size": 3,
                    "independent_first_chunk": 3,
                    "sink": 0,
                    "window_size": null
                },
                "sampling_timestep": {
                    "_class_name": "TrailingSamplingTimesteps",
                    "_config": {
                        "T": 1000,
                        "num_sampling_steps": 4,
                        "shift": 5.0
                    }
                },
                "sampler": {
                    "_class_name": "ConsistencySampler"
                },
                "positive_prompt": "assets/vbench_dynamic_degree_self_forcing_extended.txt",
                "negative_prompt": "",
                "num_samples_per_prompt": 4,
                "num_frames": 81,
                "num_prompts": 64,
                "nrow": 8,
                "shift_seed": true,
                "batch_size": 4
            }
        }
        ],
        "save_before_train": false,
        "val_before_train": false,
        "val_backbone": false,
        "val_ema_model": true,
        "step_models": ["backbone"],
        // training
        "training_steps": 160,
        "ga_steps": 1,
        "prepare_before_sync": true,
        "prepare_after_sync": false,
        // grpo
        "group_size": 32,
        "groups_per_infer": 4,
        "slices_per_step": 2,
        "optim_steps": 1,
        "reward_aggregation": "normalize_then_sum",
        "reward_field": {
            "raft_RAFT": 0.35,
            "videoalign_TA": 2.0,
            "aq_AES": 1.0,
            "iq_IMG": 1.0,
            "ms_MS": 0.75
        },
        "adv_clip_max": 5.0,
        "beta": 0.004,
        "skip_timesteps": 1,
        "policy_loss_scaling": 100.0,
        "random_policy_timestep": true
    },
    "environment": {
        "fsdp_default": {
            "cpu_offload": false
        }
    },
    "persistence": {
        "seed": 20001019,
        "output_dir": "runs/",
        "save_interval": 80,
        "val_interval": 80,
        "log_interval": 10
    },
    "dataloader": {
        "_class_name": "BaseDataloader",
        "_config": {
            "batch_size": null,
            "num_workers": 2,
            "prefetch_factor": 2,
            "pin_memory": true,
            "collate_fn": "to_list"
        },
        "dataset_cfg": {
            "_class_name": "CausalTextVideoDataset",
            "_config": {
                "paths": [
                    "assets/vidprom_motion_30725_v3_w95_action_subject.txt"
                ],
                "seed": 7343018325,
                "verbose": false,
                "total_seqlen": null,
                "max_seqlen": 32768,
                "max_seqlen_per_sample": 32768,
                "max_retries": 5,
                "height": 480,
                "width": 832,
                "num_frames": 81,
                "chunk_size": 3,
                "independent_first_chunk": 3,
                "sink": 0,
                "window_size": null,
                "sync_group_size": 1
            }
        }
    },
    "meta_model": {
        "_class_name": "CausalWan2_1_T2V",
        "_config": {
            "patch_size": [1, 2, 2],
            "vae_stride": [4, 8, 8],
            "z_dim": 16,
            "dummy_latents": true,
            "guidance_min": 3.0,
            "guidance_max": 3.0,
            "default_neg_prompt": "",
            "compile_vae_encoder": false,
            "chunk_wise_weighting": {
                "policy_losses": -1.0,
                "kl_losses": -1.0
            }
        }
    },
    "models": {
        "backbone": {
            "_class_name": "CausalWanModel",
            "_config": {
                "__inherit__": "configs/models/wan2.1_1.3B/dit_t2v.jsonc"
            },
            "weight": "runs/CausalWan2_1_T2V_DistributionMatchingDistillation/raven/states/0000220/models/backbone_ema",
            "weight_dtype": "float32",
            "mfu_enabled": true,
            "autocast": {
                "enabled": true,
                "dtype": "bfloat16"
            },
            "fsdp": {
                "enabled": true,
                "auto_wrap_policy": "wan2_1_dit_wrap_policy"
            },
            "training_state": true,
            "grad_enabled": true,
            "gradient_checkpointing": true,
            "optimizer": [{
                "_class_name": "AdamW",
                "_config": {
                    "lr": 5e-6,
                    "weight_decay": 0.0,
                    "betas": [0.0, 0.999],
                    "eps": 1e-10,
                    "fused": true
                }
            }],
            "lora": {
                "enabled": true,
                "r": 256,
                "lora_alpha": 256,
                "target_modules": [
                    "text_embedding.0", "text_embedding.2",
                    "time_embedding.0", "time_embedding.2", "time_projection.1",
                    "self_attn.q", "self_attn.k", "self_attn.v", "self_attn.o",
                    "cross_attn.q", "cross_attn.k", "cross_attn.v", "cross_attn.o",
                    "ffn.0", "ffn.2", "head.head"
                ]
            },
            "ema": {
                "enabled": true,
                "decay": 0.9675
            }
        },
        "ref_model": {
            "_class_name": "WanModel",
            "_config": {
                "__inherit__": "configs/models/wan2.1_1.3B/dit_t2v.jsonc"
            },
            "weight": "/root/models/Wan-AI/Wan2.1-T2V-1.3B/diffusion_pytorch_model.safetensors",
            "weight_dtype": "float32",
            "mfu_enabled": true,
            "autocast": {
                "enabled": true,
                "dtype": "bfloat16"
            },
            "fsdp": {
                "enabled": true,
                "auto_wrap_policy": "wan2_1_dit_wrap_policy"
            }
        },
        "reward_model": {
            "_class_name": "BaseRewardModel"
        },
        "reward_model_raft": {

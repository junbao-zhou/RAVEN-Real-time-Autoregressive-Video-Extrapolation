{
    "_class_name": "DistributionMatchingDistillation",
    "_config": {
        "training_timestep": {
            "_class_name": "UniformTrainingTimesteps",
            "_config": {
                "T": 1000,
                "shift": 5.0,
                "scaling_max": 0.98,
                "scaling_min": 0.02
            }
        },
        "fake_training_timestep": {
            "_class_name": "UniformTrainingTimesteps",
            "_config": {
                "T": 1000,
                "shift": 5.0,
                "scaling_max": 0.98,
                "scaling_min": 0.02
            }
        },
        "sampling_timestep": {
            "_class_name": "TrailingSamplingTimesteps",
            "_config": {
                "T": 1000,
                "num_sampling_steps": 4,
                "shift": 5.0
            }
        },
        "score_timestep": {
            "_class_name": "UniformTrainingTimesteps",
            "_config": {
                "T": 1000,
                "shift": 5.0,
                "scaling_max": 0.98,
                "scaling_min": 0.02
            }
        },
        "schedule": {
            "_class_name": "LinearInterpolationSchedule",
            "_config": {
                "T": 1000,
                "pred_type": "v_lerp"
            }
        },
        "sampler": {
            "_class_name": "ConsistencySampler"
        },
        "fake_schedule": {
            "_class_name": "LinearInterpolationSchedule",
            "_config": {
                "T": 1000,
                "pred_type": "v_lerp"
            }
        },
        "fake_sampler": {
            "_class_name": "DDIMSampler"
        },
        "tea_schedule": {
            "_class_name": "LinearInterpolationSchedule",
            "_config": {
                "T": 1000,
                "pred_type": "v_lerp"
            }
        },
        "tea_sampler": {
            "_class_name": "DDIMSampler"
        },
        "validation": [
        {
            "name": "vbenchdd_64x4",
            "_class_name": "GenerateT2V",
            "_config": {
                "meta_cfg": {
                    "guidance_scale": 3.0,
                    "chunk_size": 3,
                    "independent_first_chunk": 3,
                    "sink": 0,
                    "window_size": null
                },
                "sampling_timestep": {
                    "_class_name": "TrailingSamplingTimesteps",
                    "_config": {
                        "T": 1000,
                        "num_sampling_steps": 4,
                        "shift": 5.0
                    }
                },
                "sampler": {
                    "_class_name": "ConsistencySampler"
                },
                "positive_prompt": "assets/vbench_dynamic_degree_self_forcing_extended.txt",
                "negative_prompt": "",
                "num_samples_per_prompt": 4,
                "num_frames": 81,
                "num_prompts": 64,
                "nrow": 8,
                "shift_seed": true,
                "batch_size": 4
            }
        }
        ],
        "save_before_train": false,
        "val_before_train": false,
        "val_backbone": false,
        "val_ema_model": true,
        "training_steps": 220,
        "ga_steps": 1,
        "fake_loss_type": "v_lerp",
        "dmd_loss_type": "dmd",
        "norm_clip_min": 1e-5,
        "fake_random_noise": true,
        "fake_use_trajectory": false,
        "gen_use_trajectory": true,
        "gen_random_noise": false,
        "ttur_fake": 2,
        "slices_per_step": 8
    },
    "environment": {
        "fsdp_default": {
            "cpu_offload": false
        }
    },
    "persistence": {
        "seed": 20001019,
        "output_dir": "runs/",
        "save_interval": 110,
        "val_interval": 110,
        "log_interval": 10
    },
    "dataloader": {
        "_class_name": "BaseDataloader",
        "_config": {
            "batch_size": null,
            "num_workers": 2,
            "prefetch_factor": 2,
            "pin_memory": true,
            "collate_fn": "to_list"
        },
        "dataset_cfg": {
            "_class_name": "CausalTextVideoDataset",
            "_config": {
                "paths": [
                    "assets/vidprom_motion_30725_v3_w95_action_subject.txt"
                ],
                "seed": 20001019,
                "verbose": false,
                "total_seqlen": null,
                "max_seqlen": 262144,  // bs8
                // "max_seqlen": 32768,
                "max_seqlen_per_sample": 32768,
                "max_retries": 5,
                "height": 480,
                "width": 832,
                "num_frames": 81,
                "chunk_size": 3,
                "independent_first_chunk": 3,
                "sink": 0,
                "window_size": null,
                "sync_group_size": 1
            }
        }
    },
    "meta_model": {
        "_class_name": "CausalWan2_1_T2V_SF",
        "_config": {
            "patch_size": [1, 2, 2],
            "vae_stride": [4, 8, 8],
            "z_dim": 16,
            "dummy_latents": true,
            "guidance_min": 3.0,
            "guidance_max": 3.0,
            // "default_neg_prompt": "色调艳丽，过曝，静态，细节模糊不清，字幕，风格，作品，画作，画面，静止，整体发灰，最差质量，低质量，JPEG压缩残留，丑陋的，残缺的，多余的手指，画得不好的手部，画得不好的脸部，畸形的，毁容的，形态畸形的肢体，手指融合，静止不动的画面，杂乱的背景，三条腿，背景人很多，倒着走",
            "compile_vae_encoder": false,
            "chunk_wise_weighting": {
                "dmd_losses": -1.0
            }
        }
    },
    "models": {
        "backbone": {
            "_class_name": "CausalWanModel",
            "_config": {
                "__inherit__": "configs/models/wan2.1_1.3B/dit_t2v.jsonc"
            },
            "weight": "/root/models/zhuhz22/Causal-Forcing/chunkwise/causal_ode.pt",
            "weight_dtype": "float32",
            "mfu_enabled": true,
            "autocast": {
                "enabled": true,
                "dtype": "bfloat16"
            },
            "fsdp": {
                "enabled": true,
                "auto_wrap_policy": "wan2_1_dit_wrap_policy"
            },
            "training_state": true,
            "grad_enabled": true,
            "gradient_checkpointing": true,
            "optimizer": [{
                "_class_name": "AdamW",
                "_config": {
                    "lr": 2e-6,
                    "weight_decay": 0.0,
                    "betas": [0.0, 0.999],
                    "eps": 1e-08,
                    "fused": true
                }
            }],
            "lora": {
                "enabled": false,
                "r": 256,
                "lora_alpha": 256,
                "target_modules": [
                    "text_embedding.0", "text_embedding.2",
                    "time_embedding.0", "time_embedding.2", "time_projection.1",
                    "self_attn.q", "self_attn.k", "self_attn.v", "self_attn.o",
                    "cross_attn.q", "cross_attn.k", "cross_attn.v", "cross_attn.o",
                    "ffn.0", "ffn.2", "head.head"
                ]
            },
            "ema": {
                "enabled": true,
                "decay": 0.9675
            }
        },
        "fake_model": {

{
    "image_size": 224,
    "patch_size": 14,
    "dim": 1280,
    "mlp_ratio": 4,
    "out_dim": 1024,
    "num_heads": 16,
    "num_layers": 32,
    "pool_type": "token",
    "pre_norm": true,
    "post_norm": false,
    "activation": "gelu",
    "attn_dropout": 0.0,
    "proj_dropout": 0.0,
    "embedding_dropout": 0.0,
    "norm_eps": 1e-5
}